{
  "name": "nutrition-tracker-app",
  "version": "0.1.0",
  "private": true,
  "description": "Bilingual Hebrew/English manual nutrition tracking MVP.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "node scripts/run-local-date-e2e.mjs",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "test:date": "playwright test --config=playwright.unit.config.ts",
    "test:e2e:date": "node scripts/run-local-date-e2e.mjs e2e/date-correctness.spec.ts",
    "ingestion:foundation:dry-run": "node --experimental-strip-types ingestion/usda/foundation/cli.ts",
    "ingestion:foundation:promote-local": "node --experimental-strip-types ingestion/usda/foundation/promote-local.ts",
    "ingestion:foundation:approval-packet": "node --experimental-strip-types ingestion/usda/foundation/create-production-approval-packet.ts",
    "ingestion:foundation:lifecycle-rehearsal": "node --experimental-strip-types ingestion/usda/foundation/lifecycle/rehearsal.ts",
    "types:ingestion": "node scripts/check-ingestion-types.mjs --write",
    "types:ingestion:check": "node scripts/check-ingestion-types.mjs",
    "supabase:status": "supabase status",
    "supabase:version": "supabase --version"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "next": "16.2.4",
    "next-intl": "^4.9.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "supabase": "^2.95.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
