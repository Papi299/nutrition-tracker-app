# Placeholder environment file for local development.
# Do not commit .env.local or real secrets.
# Do not place service-role keys in browser-exposed NEXT_PUBLIC_* variables.

NEXT_PUBLIC_APP_NAME="Nutrition Tracker Foundation"
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# Supabase is not wired yet. These are placeholders for future public client configuration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase variables are intentionally not required yet.
# If added later, keep them out of browser/client code and do not commit real values.
