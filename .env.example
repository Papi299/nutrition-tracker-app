# Public Supabase configuration required by authentication and data clients.
# For local development, copy the local API URL and publishable key reported by
# `npx supabase status -o env` into an untracked `.env.local` file.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Do not commit real credentials. Service-role, secret, and direct database
# values are not required by this application and must never use NEXT_PUBLIC_*.
